<Window x:Class="IconvApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Iconv - Multi-frame Icon Generator" Height="650" Width="450"
        Style="{StaticResource ModernWindow}"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Iconv" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Text="Convert your images to Windows multi-size icons" Foreground="{StaticResource TextDimBrush}"/>
        </StackPanel>

        <!-- Body -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="15" BorderThickness="1" BorderBrush="#33ffffff">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Drop & Preview Zone -->
                <Grid x:Name="DropZone" Height="140" Margin="20">
                    <Rectangle Stroke="{StaticResource AccentBrush}" StrokeThickness="2" StrokeDashArray="4,4" RadiusX="10" RadiusY="10"/>
                    <TextBlock x:Name="DropText" Text="Drop Base Image Here (PNG/ICO/JPG)" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDimBrush}"/>
                    <Image x:Name="SourcePreview" Stretch="Uniform" Margin="10" Visibility="Collapsed"/>
                </Grid>

                <!-- Resolution Previews -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ResolutionItemsControl" Margin="20,0,20,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10" Background="#11ffffff">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox IsChecked="{Binding IsIncluded}" Margin="10,0" VerticalAlignment="Center" Style="{StaticResource ModernCheckBox}"/>
                                    
                                    <Border Grid.Column="1" Width="64" Height="64" Background="#22000000" Margin="0,5,10,5" 
                                            AllowDrop="True" Drop="ResolutionItem_Drop" DragOver="ResolutionItem_DragOver">
                                        <Image Source="{Binding Image}" Stretch="Uniform"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SizeText}" Foreground="{StaticResource TextBrush}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Margin="0,25,0,0">
            <Button x:Name="ExportButton" Content="Export Multi-size Icon" 
                    Style="{StaticResource PrimaryButton}"
                    Click="ExportButton_Click" IsEnabled="False"/>
            <TextBlock x:Name="StatusLabel" Text="Ready" HorizontalAlignment="Center" 
                       Margin="0,10,0,0" Foreground="{StaticResource TextDimBrush}" FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
