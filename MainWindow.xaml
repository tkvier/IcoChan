<Window x:Class="IconvApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Multi-Frame Icon Generator - IcoChan" Height="700" Width="550"
        Style="{StaticResource ModernWindow}"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="IcoChan" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                <TextBlock Text="Convert your Image to Windows Multi-Frame Icon" Foreground="{DynamicResource TextDimBrush}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Dark Background" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12" Foreground="{DynamicResource TextDimBrush}"/>
                <CheckBox x:Name="ThemeToggle" IsChecked="True" Checked="ThemeToggle_Changed" Unchecked="ThemeToggle_Changed" Style="{StaticResource ModernCheckBox}"/>
            </StackPanel>
        </Grid>

        <!-- Body -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="15" BorderThickness="1" BorderBrush="#33ffffff">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Drop & Preview Zone -->
                <Grid x:Name="DropZone" Height="140" Margin="20">
                    <Rectangle Stroke="{DynamicResource AccentBrush}" StrokeThickness="2" StrokeDashArray="4,4" RadiusX="10" RadiusY="10"/>
                    <TextBlock x:Name="DropText" Text="Drop Base Image Here (PNG/ICO/JPG)" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextDimBrush}"/>
                    <Image x:Name="SourcePreview" Stretch="Uniform" Margin="10" Visibility="Collapsed"/>
                </Grid>

                <!-- Resolution Previews -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ResolutionItemsControl" Margin="20,0,20,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8" Width="90">
                                    <Grid HorizontalAlignment="Center">
                                        <Border Width="64" Height="64" Background="#22000000" CornerRadius="8"
                                                AllowDrop="True" Drop="ResolutionItem_Drop" DragOver="ResolutionItem_DragOver">
                                            <Image Source="{Binding Image}" Stretch="Uniform" Margin="4"/>
                                        </Border>
                                        <CheckBox IsChecked="{Binding IsIncluded}" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                                  Margin="-5,-5,0,0" Style="{StaticResource ModernCheckBox}"/>
                                    </Grid>
                                    
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource TextBrush}" 
                                                   FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextDimBrush}" 
                                                   FontSize="10" HorizontalAlignment="Center" TextAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Margin="0,25,0,0">
            <Button x:Name="ExportButton" Content="Export Multi-Frame Icon" 
                    Style="{StaticResource PrimaryButton}" Height="30"
                    Click="ExportButton_Click" IsEnabled="False"/>
            <TextBlock x:Name="StatusLabel" Text="Ready" HorizontalAlignment="Center" 
                       Margin="0,10,0,0" Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
